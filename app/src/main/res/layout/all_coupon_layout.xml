<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="2dp"
        android:layout_marginRight="2dp"
        android:layout_marginBottom="7dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/card_corners"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/all_coupon_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="hehehhehe"
                    android:textColor="@color/black"
                    android:textSize="@dimen/hint_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/all_coupon_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right|center"
                    android:text="hehehhehe"
                    android:textColor="@color/Login_theme"
                    android:textSize="@dimen/hint_text_size"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/all_coupon_subname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="hahahha"
                android:textSize="@dimen/small_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/all_coupon_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="MAXSAFETY"
                    android:textSize="@dimen/small_text" />

                <!--                <View-->
                <!--                    android:layout_width="10dp"-->
                <!--                    android:layout_height="1dp"-->
                <!--                    android:layout_gravity="center"-->
                <!--                    android:layout_marginStart="5dp"-->
                <!--                    android:layout_marginEnd="5dp"-->
                <!--                    android:background="@color/default_color" />-->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:text="to"
                    android:textSize="@dimen/small_text" />

                <TextView
                    android:id="@+id/all_coupon_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAXSAFETY"
                    android:textSize="@dimen/small_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/all_coupon_discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discount"
                    android:textColor="@color/black"
                    android:textSize="@dimen/hint_text_size"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/up_to"
                    android:textColor="@color/black"
                    android:textSize="@dimen/hint_text_size" />

                <TextView
                    android:id="@+id/all_coupon_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:drawableLeft="@drawable/baseline_currency_rupee_24"
                    android:gravity="center"
                    android:text="@string/Discount"
                    android:textColor="@color/black"
                    android:textSize="@dimen/hint_text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/all_coupon_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_line"
                    android:gravity="center"
                    android:padding="6dp"
                    android:text="MAXSAFETY"
                    android:textColor="@color/Login_theme"
                    android:textSize="@dimen/button_text_size" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/all_coupon_copy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#00000000"
                    android:gravity="right|center"
                    android:text="@string/copy_button"
                    android:textAllCaps="false"
                    android:textColor="@color/Login_theme"
                    android:textSize="@dimen/button_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>

