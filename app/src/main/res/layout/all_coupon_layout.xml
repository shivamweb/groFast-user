<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/linear_padding">

        <TextView
            android:id="@+id/all_coupon_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="hehehhehe"
            android:textColor="@color/black"
            android:textSize="20dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/all_coupon_subname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="hahahha" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/all_coupon_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:background="@drawable/textview_design"
                android:gravity="center"
                android:padding="10dp"
                android:text="MAXSAFETY"
                android:textColor="@color/Login_theme"
                android:textSize="@dimen/button_text_size" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/all_coupon_copy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#00000000"
                android:gravity="right|center"
                android:text="@string/copy_button"
                android:textAllCaps="false"
                android:textColor="@color/Login_theme"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="wrap_content"
        android:layout_height="1dp"
        android:background="@color/line_color" />

</LinearLayout>

